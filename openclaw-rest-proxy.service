[Unit]
Description=OpenClaw REST-to-WebSocket Proxy
After=network.target openclaw-gateway.service

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/openclaw-rest-proxy
ExecStart=/usr/bin/node openclaw-rest-proxy.js
Restart=always
RestartSec=5
Environment=OPENCLAW_GATEWAY_TOKEN=%FILL_IN%
Environment=OPENCLAW_WS_URL=ws://localhost:18789
Environment=PROXY_PORT=18790

[Install]
WantedBy=default.target
